# .env.example
# Copy to .env and fill in your values.
# The GhostCacher sidecar forwards requests to the upstream LLM provider
# using these credentials — they are never stored in Redis or logs.

# ── LLM Provider API Keys ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# ── Sidecar Configuration ────────────────────────────────────────────────────
GC_LISTEN_ADDR=0.0.0.0:8080
GC_METRICS_ADDR=0.0.0.0:9090
GC_UPSTREAM_URL=https://api.anthropic.com/v1/messages
GC_REDIS_URL=redis://localhost:6379
GC_REQUEST_TIMEOUT_SECS=120
GC_HBM_SWAP_THRESHOLD=0.85
GC_GHOST_LOCK_TIMEOUT_SECS=30
GC_RDMA_ENABLED=false
GC_LOG_LEVEL=info

# ── Control Plane Configuration ──────────────────────────────────────────────
GC_CP_LISTEN_ADDR=0.0.0.0:7070
GC_CP_REDIS_URL=redis://localhost:6379
GC_CP_EVICTION_INTERVAL_SECS=300
GC_CP_MAX_CACHE_ENTRIES=10000

# ── KV Relay Configuration ───────────────────────────────────────────────────
GC_RELAY_GRPC_ADDR=0.0.0.0:50051
GC_RELAY_HTTP_ADDR=0.0.0.0:50052
GC_RELAY_RDMA_AVAILABLE=false
GC_RELAY_MAX_CONCURRENT_STREAMS=16

# ── Dev Tool URLs (used by scripts/dev.sh) ───────────────────────────────────
GC_SIDECAR_URL=http://localhost:8080
GC_CP_URL=http://localhost:7070
